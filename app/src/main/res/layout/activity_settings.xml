<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <!-- 1. TOP BAR: LAYERS -->
    <LinearLayout
        android:id="@+id/layoutTopLayers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#2D2D2D"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Layers" android:textColor="#FFFFFF" android:textStyle="bold" />
            <Button android:id="@+id/btnAddLayer" style="?android:attr/buttonStyleSmall" android:layout_width="wrap_content" android:layout_height="32dp" android:layout_alignParentEnd="true" android:text="+ Add" />
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerLayers"
            android:layout_width="match_parent"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- 2. MIDDLE: CANVAS -->
    <FrameLayout
        android:id="@+id/canvasContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTopLayers"
        app:layout_constraintBottom_toTopOf="@id/layoutControlPanel">

        <ame.project.n2live.gl.SpriteGLSurfaceView
            android:id="@+id/glSurfacePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- 2.5 DEDICATED CONTROL PANEL (Prevents image overlap) -->
    <LinearLayout
        android:id="@+id/layoutControlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#2D2D2D"
        android:padding="4dp"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomTimeline">

        <!-- Position & Scale -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical"
            android:padding="4dp"
            android:background="#333"
            android:layout_margin="2dp">
            <TextView android:id="@+id/tvActiveLayerName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Layer: None" android:textColor="#FFF" android:textSize="10sp" android:textStyle="bold" />
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="X" android:textColor="#FFF" android:textSize="10sp"/>
                <SeekBar android:id="@+id/sliderPosX" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="200" android:progress="100" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="Y" android:textColor="#FFF" android:textSize="10sp"/>
                <SeekBar android:id="@+id/sliderPosY" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="200" android:progress="100" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="S" android:textColor="#FFF" android:textSize="10sp"/>
                <SeekBar android:id="@+id/sliderScale" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="200" android:progress="100" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                <TextView android:layout_width="12dp" android:layout_height="wrap_content" android:text="Z" android:textColor="#FFF" android:textSize="10sp"/>
                <SeekBar android:id="@+id/sliderPosZ" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="20" android:progress="0" />
            </LinearLayout>
        </LinearLayout>

        <!-- Preview State Buttons -->
        <GridLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:columnCount="2"
            android:padding="2dp"
            android:alignmentMode="alignMargins">
            <Button android:id="@+id/btnPreviewPlay" style="?android:attr/buttonStyleSmall" android:layout_width="60dp" android:layout_height="32dp" android:text="Play" android:textSize="9sp" />
            <Button android:id="@+id/btnPreviewIdle" style="?android:attr/buttonStyleSmall" android:layout_width="60dp" android:layout_height="32dp" android:text="Idle" android:textSize="9sp" />
            <Button android:id="@+id/btnPreviewTalk" style="?android:attr/buttonStyleSmall" android:layout_width="60dp" android:layout_height="32dp" android:text="Talk" android:textSize="9sp" />
            <Button android:id="@+id/btnPreviewAngry" style="?android:attr/buttonStyleSmall" android:layout_width="60dp" android:layout_height="32dp" android:text="Angry" android:textSize="9sp" />
        </GridLayout>
    </LinearLayout>

    <!-- 3. BOTTOM: TIMELINE EDITOR (Multi-Track) -->
    <LinearLayout
        android:id="@+id/layoutBottomTimeline"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:orientation="vertical"
        android:background="#252525"
        app:layout_constraintBottom_toTopOf="@id/btnSaveConfig">

        <!-- Scrubber Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="8dp"
            android:background="#333">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Duration:" android:textColor="#AAA" android:textSize="10sp" />
                <SeekBar android:id="@+id/sliderDuration" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:max="60" android:progress="5" />
                <TextView android:id="@+id/tvDurationValue" android:layout_width="40dp" android:layout_height="wrap_content" android:text="5s" android:textColor="#FFF" android:textSize="10sp" android:gravity="end" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <Spinner android:id="@+id/spinnerStateName" android:layout_width="100dp" android:layout_height="36dp" />
                <SeekBar android:id="@+id/timelineScrubber" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
                <TextView android:id="@+id/tvTimelineTime" android:layout_width="60dp" android:layout_height="wrap_content" android:text="0.00s" android:textColor="#FFF" android:textSize="12sp" android:gravity="center" />
                <CheckBox android:id="@+id/cbLoop" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loop" android:textColor="#FFF" android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <!-- Time Markers / Ruler -->
                <LinearLayout android:id="@+id/timelineRuler" android:layout_width="wrap_content" android:layout_height="24dp" android:orientation="horizontal" />
                <!-- Tracks for each layer -->
                <ScrollView android:layout_width="wrap_content" android:layout_height="match_parent">
                    <LinearLayout android:id="@+id/timelineTracks" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" />
                </ScrollView>
            </LinearLayout>
        </HorizontalScrollView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSourceFiles"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#1A1A1A" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnPickFolder" style="?android:attr/buttonStyleSmall" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Import PNG" />
            <Button android:id="@+id/btnSaveState" style="?android:attr/buttonStyleSmall" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Apply to State" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveConfig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="EXPORT CONFIG.JSON"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
